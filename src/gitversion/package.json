{
    "name": "@tomgrv-devcontainer-features/gitversion",
    "version": "7.2.0",
    "description": "GitVersion integration and version management scripts",
    "files": [
        "_*.sh",
        "install.sh",
        "install-tools.sh",
        "_scripts.package.json",
        "stubs/**/*"
    ],
    "bin": {
        "bump-changelog": "./_bump-changelog.sh",
        "bump-tag": "./_bump-tag.sh",
        "bump-version": "./_bump-version.sh",
        "checkout-version": "./_checkout-version.sh",
        "gv": "./_gv.sh"
    },
    "scripts": {
        "install": "if [ \"$INIT_CWD\" = \"$PWD\" ]; then sh ./install.sh; fi",
        "postinstall": "if [ \"$INIT_CWD\" = \"$PWD\" ]; then configure-feature -s . gitversion; fi"
    },
    "dependencies": {},
    "peerDependencies": {
        "@tomgrv-devcontainer-features/common-utils": ">=5.0.0"
    }
}
