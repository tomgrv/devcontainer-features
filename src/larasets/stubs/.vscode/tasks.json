{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "🚀 Start",
            "detail": "Start the full dev environment (auto-detects Sail vs local, Codespaces/dev container/web/local)",
            "dependsOn": [
                "❇️ Optimize",
                "serve",
                "vite",
                "art-queue",
                "art-schedule",
                "logs",
                "smee"
            ],
            "dependsOrder": "parallel",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "❇️ Optimize",
            "type": "shell",
            "command": "art optimize",
            "presentation": {
                "panel": "dedicated",
                "clear": true,
                "reveal": "always",
                "close": true
            }
        },
        {
            "label": "🔄️ Refresh",
            "type": "shell",
            "command": "art migrate:fresh --seed",
            "presentation": {
                "panel": "dedicated",
                "clear": true,
                "reveal": "always",
                "close": true
            }
        },
        {
            "label": "serve",
            "type": "shell",
            "command": "serve",
            "hide": true,
            "presentation": {
                "panel": "dedicated",
                "clear": true,
                "reveal": "always"
            },
            "problemMatcher": {
                "owner": "artisan",
                "fileLocation": ["relative", "${workspaceFolder}"],
                "source": "artisan",
                "pattern": [
                    {
                        "regexp": "Exception",
                        "message": 1
                    },
                    {
                        "regexp": "^\\s*at\\s*([/\\w]+):(\\d+)$",
                        "file": 1,
                        "line": 2
                    }
                ],
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^\\s*(INFO)",
                    "endsPattern": "."
                }
            }
        },
        {
            "label": "logs",
            "type": "shell",
            "command": "tail -f storage/logs/laravel.log",
            "hide": true,
            "presentation": {
                "panel": "dedicated",
                "clear": true,
                "reveal": "silent",
                "close": true
            },
            "problemMatcher": []
        },
        {
            "label": "smee",
            "type": "shell",
            "command": "npm run smee",
            "hide": true,
            "presentation": {
                "panel": "dedicated",
                "clear": true,
                "reveal": "silent",
                "close": true
            },
            "problemMatcher": []
        },
        {
            "label": "⤵️ Install",
            "dependsOn": ["composer inst", "npm install"],
            "dependsOrder": "parallel"
        },
        {
            "label": "sail-restart",
            "type": "shell",
            "command": "sail restart",
            "presentation": {
                "panel": "dedicated",
                "clear": true,
                "close": true
            },
            "hide": true
        },
        {
            "label": "sail-down",
            "type": "shell",
            "command": "sail down",
            "presentation": {
                "panel": "dedicated",
                "clear": true,
                "close": true
            },
            "hide": true
        },
        {
            "label": "art-queue",
            "type": "shell",
            "command": "art queue:listen --sleep=3 --tries=3",
            "presentation": {
                "panel": "dedicated",
                "clear": true,
                "reveal": "silent"
            },
            "hide": true,
            "isBackground": true,
            "problemMatcher": {
                "owner": "artisan",
                "fileLocation": ["relative", "${workspaceFolder}"],
                "source": "artisan",
                "pattern": [
                    {
                        "regexp": "Exception",
                        "message": 1
                    },
                    {
                        "regexp": "^\\s*at\\s*([/\\w]+):(\\d+)$",
                        "file": 1,
                        "line": 2
                    }
                ],
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^\\s*(INFO)",
                    "endsPattern": "."
                }
            }
        },
        {
            "label": "art-schedule",
            "type": "shell",
            "command": "art schedule:work",
            "presentation": {
                "panel": "dedicated",
                "clear": true,
                "reveal": "silent"
            },
            "hide": true,
            "isBackground": true,
            "problemMatcher": {
                "owner": "artisan",
                "fileLocation": ["relative", "${workspaceFolder}"],
                "source": "artisan",
                "pattern": [
                    {
                        "regexp": "Exception",
                        "message": 1
                    },
                    {
                        "regexp": "^\\s*at\\s*([/\\w]+):(\\d+)$",
                        "file": 1,
                        "line": 2
                    }
                ],
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^\\s*(INFO)",
                    "endsPattern": "."
                }
            }
        },
        {
            "label": "vite",
            "type": "shell",
            "command": "srv dev",
            "presentation": {
                "panel": "dedicated",
                "clear": true,
                "reveal": "always"
            },
            "hide": true,
            "isBackground": true,
            "problemMatcher": {
                "owner": "vite",
                "fileLocation": ["relative", "${workspaceFolder}"],
                "source": "vite",
                "pattern": {
                    "regexp": "^\\s*(Error)\\s*(.*)$",
                    "file": 1,
                    "line": 2,
                    "column": 3,
                    "severity": 4,
                    "message": 5
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^VITE v\\d+\\.\\d+\\.\\d+\\s+ready in \\d+ ms$",
                    "endsPattern": "."
                }
            }
        },
        {
            "label": "art-cache-config",
            "type": "shell",
            "command": "art config:cache",
            "hide": true,
            "presentation": {
                "panel": "shared",
                "reveal": "silent",
                "close": true
            },
            "problemMatcher": []
        },
        {
            "label": "art-cache-views",
            "type": "shell",
            "command": "art view:cache",
            "hide": true,
            "presentation": {
                "panel": "shared",
                "reveal": "silent",
                "close": true
            },
            "problemMatcher": []
        },
        {
            "label": "art-cache-routes",
            "type": "shell",
            "command": "art route:cache",
            "hide": true,
            "presentation": {
                "panel": "shared",
                "reveal": "silent",
                "close": true
            },
            "problemMatcher": []
        },
        {
            "label": "📝 Ide Helper",
            "type": "shell",
            "command": "art ide-helper:generate --ansi && art ide-helper:meta --ansi && art ide-helper:models --write --ansi",
            "presentation": {
                "panel": "shared",
                "close": true,
                "reveal": "silent"
            }
        }
    ]
}
