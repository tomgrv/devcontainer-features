{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "🚀 Start",
            "detail": "Start the full dev environment with Sail/PHP + queue + jobs + vite (auto-detects Sail vs local), then logs, schedule, and smee, in order",
            "dependsOn": [
                "❇️ Optimize",
                "serve",
                "logs",
                "art-schedule",
                "smee"
            ],
            "dependsOrder": "sequence",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "❇️ Optimize",
            "type": "shell",
            "command": "art optimize",
            "presentation": {
                "panel": "dedicated",
                "clear": true,
                "reveal": "always",
                "close": true
            }
        },
        {
            "label": "🔄️ Refresh",
            "type": "shell",
            "command": "art migrate:fresh --seed",
            "presentation": {
                "panel": "dedicated",
                "clear": true,
                "reveal": "always",
                "close": true
            }
        },
        {
            "label": "serve",
            "type": "shell",
            "command": "sh -c 'echo READY; exec serve'",
            "detail": "Orchestrate Sail/PHP + queue + jobs + vite (pm2-managed)",
            "hide": true,
            "isBackground": true,
            "presentation": {
                "panel": "dedicated",
                "clear": true,
                "reveal": "always"
            },
            "problemMatcher": {
                "owner": "artisan",
                "fileLocation": ["relative", "${workspaceFolder}"],
                "source": "artisan",
                "pattern": [
                    {
                        "regexp": "Exception",
                        "message": 1
                    },
                    {
                        "regexp": "^\\s*at\\s*([/\\w]+):(\\d+)$",
                        "file": 1,
                        "line": 2
                    }
                ],
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^READY$",
                    "endsPattern": "."
                }
            }
        },
        {
            "label": "logs",
            "type": "shell",
            "command": "sh -c 'echo READY; exec tail -f storage/logs/laravel.log'",
            "hide": true,
            "isBackground": true,
            "presentation": {
                "panel": "dedicated",
                "clear": true,
                "reveal": "silent",
                "close": true
            },
            "problemMatcher": {
                "pattern": {
                    "regexp": "^(.)$",
                    "file": 1
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^READY$",
                    "endsPattern": "."
                }
            }
        },
        {
            "label": "smee",
            "type": "shell",
            "command": "smee",
            "hide": true,
            "presentation": {
                "panel": "dedicated",
                "clear": true,
                "reveal": "silent",
                "close": true
            },
            "problemMatcher": []
        },
        {
            "label": "⤵️ Install",
            "dependsOn": ["composer inst", "npm install"],
            "dependsOrder": "parallel"
        },
        {
            "label": "sail-restart",
            "type": "shell",
            "command": "sail restart",
            "presentation": {
                "panel": "dedicated",
                "clear": true,
                "close": true
            },
            "hide": true
        },
        {
            "label": "sail-down",
            "type": "shell",
            "command": "sail down",
            "presentation": {
                "panel": "dedicated",
                "clear": true,
                "close": true
            },
            "hide": true
        },
        {
            "label": "art-schedule",
            "type": "shell",
            "command": "sh -c 'echo READY; exec art schedule:work'",
            "presentation": {
                "panel": "dedicated",
                "clear": true,
                "reveal": "silent"
            },
            "hide": true,
            "isBackground": true,
            "problemMatcher": {
                "owner": "artisan",
                "fileLocation": ["relative", "${workspaceFolder}"],
                "source": "artisan",
                "pattern": [
                    {
                        "regexp": "Exception",
                        "message": 1
                    },
                    {
                        "regexp": "^\\s*at\\s*([/\\w]+):(\\d+)$",
                        "file": 1,
                        "line": 2
                    }
                ],
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^READY$",
                    "endsPattern": "."
                }
            }
        },
        {
            "label": "art-cache-config",
            "type": "shell",
            "command": "art config:cache",
            "hide": true,
            "presentation": {
                "panel": "shared",
                "reveal": "silent",
                "close": true
            },
            "problemMatcher": []
        },
        {
            "label": "art-cache-views",
            "type": "shell",
            "command": "art view:cache",
            "hide": true,
            "presentation": {
                "panel": "shared",
                "reveal": "silent",
                "close": true
            },
            "problemMatcher": []
        },
        {
            "label": "art-cache-routes",
            "type": "shell",
            "command": "art route:cache",
            "hide": true,
            "presentation": {
                "panel": "shared",
                "reveal": "silent",
                "close": true
            },
            "problemMatcher": []
        },
        {
            "label": "📝 Ide Helper",
            "type": "shell",
            "command": "art ide-helper:generate --ansi && art ide-helper:meta --ansi && art ide-helper:models --write --ansi",
            "presentation": {
                "panel": "shared",
                "close": true,
                "reveal": "silent"
            }
        }
    ]
}
