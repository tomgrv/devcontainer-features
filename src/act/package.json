{
    "name": "@tomgrv-devcontainer-features/act",
    "version": "7.0.0",
    "description": "Nektos Act - GitHub Actions local runner integration",
    "files": [
        "_*.sh",
        "install.sh",
        "install-act.sh",
        "stubs/**/*"
    ],
    "bin": {
        "act-reset": "./_act-reset.sh",
        "act-run": "./_act-run.sh"
    },
    "scripts": {
        "install": "if [ \"$INIT_CWD\" = \"$PWD\" ]; then sh ./install.sh; fi",
        "install-act": "./install-act.sh",
        "postinstall": "if [ \"$INIT_CWD\" = \"$PWD\" ]; then configure-feature -s . act; fi"
    },
    "peerDependencies": {
        "@tomgrv-devcontainer-features/common-utils": ">=5.0.0"
    }
}
