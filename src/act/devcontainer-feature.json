{
    "description": "A tool for running GitHub Actions locally",
    "id": "act",
    "installsAfter": [
        "ghcr.io/devcontainers/features/docker-in-docker",
        "ghcr.io/tomgrv/devcontainer-features/common-utils"
    ],
    "dependsOn": {
        "ghcr.io/devcontainers/features/docker-in-docker:3": {},
        "ghcr.io/tomgrv/devcontainer-features/common-utils:7": {}
    },
    "name": "Nektos Act",
    "options": {
        "version": {
            "type": "string",
            "description": "The version of act to install",
            "default": "master"
        }
    },
    "version": "7.2.0",
    "postCreateCommand": {
        "config": "configure-feature act"
    }
}
