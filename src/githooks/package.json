{
    "name": "@tomgrv-devcontainer-features/githooks",
    "version": "5.44.0",
    "description": "Git hooks and linting configuration for development workflow",
    "files": [
        "_*.sh",
        "configure-*.sh",
        "install.sh",
        "_*.package.json",
        "stubs/**/*"
    ],
    "bin": {
        "commit-msg": "./_commit-msg.sh",
        "install-plugins": "./_install-plugins.sh",
        "post-checkout": "./_post-checkout.sh",
        "post-merge": "./_post-merge.sh",
        "pre-commit": "./_pre-commit.sh",
        "pre-push": "./_pre-push.sh",
        "prepare-commit-msg": "./_prepare-commit-msg.sh",
        "sync-versions": "./_sync-versions.sh",
        "update-version": "./_update-version.sh"
    },
    "scripts": {
        "configure-cz": "./configure-cz.sh",
        "configure-hooks": "./configure-hooks.sh"
    },
    "dependencies": {
        "@commitlint/cli": "*",
        "@commitlint/config-conventional": "*",
        "@commitlint/config-workspace-scopes": "*",
        "@commitlint/cz-commitlint": "*",
        "commit-and-tag-version": "*",
        "commitizen": "*",
        "git-precommit-checks": "*",
        "lint-staged": "*",
        "prettier": "*",
        "prettier-plugin-sh": "*"
    },
    "peerDependencies": {
        "@tomgrv-devcontainer-features/common-utils": "^5.0.0",
        "@tomgrv-devcontainer-features/gitutils": "^5.0.0"
    }
}
