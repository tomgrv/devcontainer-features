{
    "customizations": {
        "vscode": {
            "settings": {
                "conventionalCommits.gitmoji": false,
                "github.copilot.chat.commitMessageGeneration.instructions": [
                    {
                        "file": ".github/instructions/commit.instructions.md"
                    }
                ],
                "[javascript]": {
                    "editor.defaultFormatter": "esbenp.prettier-vscode"
                },
                "[json]": {
                    "editor.defaultFormatter": "esbenp.prettier-vscode"
                }
            },
            "extensions": [
                "vivaxy.vscode-conventional-commits",
                "softwareape.rebaser",
                "tomblind.scm-buttons-vscode"
            ]
        }
    },
    "description": "A feature to add useful Git hooks to your project",
    "id": "githooks",
    "installsAfter": [
        "ghcr.io/tomgrv/devcontainer-features/common-utils",
        "ghcr.io/tomgrv/devcontainer-features/gitversion",
        "ghcr.io/tomgrv/devcontainer-features/gitutils"
    ],
    "dependsOn": {
        "ghcr.io/devcontainers/features/node:1": {
            "version": "lts"
        },
        "ghcr.io/tomgrv/devcontainer-features/gitutils:7": {}
    },
    "name": "Git Hooks",
    "version": "7.2.0",
    "postCreateCommand": {
        "config": "configure-feature githooks"
    }
}
