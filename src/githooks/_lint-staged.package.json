{
    "scripts": {
        "lint": "npx --yes lint-staged -p false"
    },
    "peerDependencies": {
        "@tomgrv-devcontainer-features/common-utils": "^5",
        "prettier": "*"
    },
    "lint-staged": {
        "!(*schema).json": [
            "normalize-json -c -w -a -i -t 4 -f local -l true"
        ],
        "!(templates/**/*).{js,jsx,ts,tsx,md,html,css,vue,yaml,yml,json}": [
            "npx --yes prettier --write"
        ]
    }
}
